# ============================================================================
# zpa-collector configuration. Copy to .env and fill in. Required vars first.
# ============================================================================

# --- OneAPI: own READ-ONLY client (role limited to config read) -------------
ZS_VANITY_DOMAIN=acme            # -> acme.zslogin.net (token endpoint)
ZS_CLIENT_ID=                    # OneAPI client id (required)
ZS_CLIENT_SECRET=                # OneAPI client secret (required)
ZPA_CUSTOMER_ID=                 # ZPA tenant / customer id (required)

# --- Dashboard / export / sync auth -----------------------------------------
DASH_TOKEN=                      # shared token; sent as X-Dash-Token or HTTP Basic (required)

# --- LSS TLS receiver -------------------------------------------------------
LSS_PORT=4639                    # TLS receiver port (the LSS config points here)
LSS_CERT_PATH=/data/receiver.crt # receiver TLS cert — YOU provide one (see README §2); stdlib can't mint certs
LSS_KEY_PATH=/data/receiver.key  # receiver TLS key  — provision alongside the cert on the /data volume
DEDUP_TTL_SECONDS=300            # ConnectionID dedup TTL (open+close -> one count)
MAX_LINE_BYTES=65536             # over-long lines are dropped + counted

# --- Classification defaults (live-overridable in the UI) -------------------
WARM_DAYS=7                      # green band: seen within N days
STALE_DAYS=30                    # yellow band cutoff; older -> orange
WINDOW_DAYS=30                   # observation-horizon label for the CSV header

# --- Serving ----------------------------------------------------------------
HTTP_PORT=8866                   # dashboard / API / CSV port

# --- Engine -----------------------------------------------------------------
FLUSH_SECONDS=30                 # counter -> SQLite flush interval
DB_PATH=/data/state.db           # SQLite (WAL) state file
CONFIG_SYNC_HOUR=2               # nightly config-sync hour (UTC)

# --- Privacy / sampling -----------------------------------------------------
USER_SAMPLE_ENABLED=true         # capture the small plaintext username sample
RECENT_USERS_MAX=50              # username-sample ring size (distinct emails per object)

# --- Scoping / advisory -----------------------------------------------------
DONOTRETIRE_LIST=                # comma-separated object names excluded from candidates (APPLIED)
CONNECTOR_GROUP_FILTER=          # RESERVED (not yet applied in v1): scope the report to these connector groups
HEALTH_WEBHOOK=                  # RESERVED (not yet wired in v1): outbound URL for DEGRADED/AT-RISK alerts
